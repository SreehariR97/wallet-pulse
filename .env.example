# ---- Auth ----
# Generate with: openssl rand -base64 32. Use the SAME value for both
# NEXTAUTH_SECRET and AUTH_SECRET — Auth.js v5 reads AUTH_SECRET, our code
# still references NEXTAUTH_SECRET in a few places.
NEXTAUTH_SECRET=your-secret-here
AUTH_SECRET=your-secret-here
# NEXTAUTH_URL is your base URL. Local dev uses plain http://, not https://
# — pair with AUTH_TRUST_HOST=true below so Auth.js doesn't reject it.
NEXTAUTH_URL=http://localhost:3000
# Required for local dev over plain HTTP (and for any non-https production
# host). Without this, Auth.js fails with a Configuration error on every
# auth callback because it refuses to trust a non-https host by default.
AUTH_TRUST_HOST=true

# ---- Database ----
# Neon serverless Postgres — sign up at https://console.neon.tech and paste
# the pooled connection string (recommended for serverless). It looks like:
#   postgres://user:pass@ep-xxxxx-pooler.us-east-2.aws.neon.tech/walletpulse?sslmode=require
# Any Postgres-compatible URL works (Supabase, Railway, RDS, local Postgres, etc.).
DATABASE_URL=postgres://user:pass@host/walletpulse?sslmode=require
